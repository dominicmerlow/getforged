# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Anthropic ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# FREE ALTERNATIVE: GROQ_API_KEY=gsk_...  (use groq sdk + llama-3.1-8b)

# ── Firecrawl ──────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...
# FREE ALTERNATIVE: leave blank to use built-in fetch + cheerio scraper

# ── Resend ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@getforged.io
# FREE ALTERNATIVE: set SMTP_* vars below to use Gmail SMTP (nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

# ── Stripe ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://getforged.io
GETFORGED_COMMISSION_RATE=0.15
